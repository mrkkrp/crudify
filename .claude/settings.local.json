{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(timeout 120 nix eval --raw .#packages.x86_64-linux.default.name)",
      "Bash(timeout 60 nix eval nixpkgs#libraw.dev.outPath)",
      "Bash(timeout 60 nix eval --raw nixpkgs#hugin.pname)",
      "Bash(cargo generate-lockfile *)",
      "Bash(nix flake *)",
      "Bash(nix develop *)",
      "Bash(nix shell *)",
      "Bash(nix run *)",
      "Bash(git add *)",
      "Bash(nix eval --impure --expr ' *)",
      "Bash(echo \"===EXIT: $?===\")",
      "Bash(curl -sS \"https://crates.io/api/v1/crates/image\")",
      "Bash(curl -sS -A \"crudify-dev\" \"https://crates.io/api/v1/crates/image\")",
      "Read(//tmp/**)",
      "Bash(curl -sSL -A \"crudify-dev\" \"https://docs.rs/crate/exoquant/0.2.0/source/src/lib.rs\")",
      "Bash(echo \"===EXIT $?===\")"
    ]
  }
}
